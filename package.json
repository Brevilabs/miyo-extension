{
  "name": "miyo-extension",
  "version": "0.1.0",
  "description": "Sync your AI chat history (ChatGPT, Claude) into local markdown files for Miyo and any tool that reads markdown.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:watch": "node scripts/build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "package": "npm run build && node scripts/package.mjs",
    "version": "node scripts/sync-version.mjs"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0"
  }
}
