{
  "manifest_version": 3,
  "key": "",
  "name": "Miyo Capture",
  "short_name": "Miyo Capture",
  "version": "0.3.7",
  "description": "Auto-sync your ChatGPT and Claude chats to local markdown files. Yours on your machine, never the cloud.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Miyo Capture",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "alarms",
    "nativeMessaging"
  ],
  "optional_permissions": [
    "cookies"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://*.chatgpt.com/*",
    "https://claude.ai/*",
    "https://*.claude.ai/*"
  ]
}
